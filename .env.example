# Browser-visible configuration. Never place provider credentials in VITE_* variables.
VITE_DECISION_API_MODE=replay
VITE_DECISION_API_URL=/api/compile

# Server-only secret used by api/compile.ts. Do not expose to the client bundle.
GEMINI_API_KEY=replace-with-server-side-secret
GEMINI_MODEL=gemini-2.5-flash
ALLOWED_ORIGIN=http://localhost:5173
